Vagrant.configure("2") do |config|
    #common configuration
    config.ssh.insert_key = false

    #first vm Ubuntu
    config.vm.define "ubuntu" do |ubuntu|
        ubuntu.vm.box = "ubuntu/focal64"
        ubuntu.vm.hostname = "ubuntu-vm"
        ubuntu.vm.network  "private_network", ip: "192.168.56.10"
        ubuntu.vm.provider "virtualbox" do |vb|
            vb.memory =1024
            vb.cpus = 1
        end
        ubuntu.vm.provision "shell" , inline: <<-SHELL
          sudo apt update
          # Installer Python 3 et pip
          sudo apt install -y python3 python3-pip

          # Installer des librairies Python globalement
          pip3 install --upgrade pip
          pip3 install requests 
          mkdir -p /home/vagrant/.ssh
          echo "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGzAHaxmp1KTOKMMC5u14cpbTX0WUM1Xnve0GBCL99cm assag@DESKTOP-APSQTK1" >> /home/vagrant/.ssh/authorized_keys
          chmod 600 /home/vagrant/.ssh/authorized_keys
          chown -R vagrant:vagrant /home/vagrant/.ssh
        SHELL
    end

#second vms linux centos/stream9
    config.vm.define "centos" do |centos|
        centos.vm.box = "centos/stream9"
        centos.vm.hostname = "centos-vm"
        centos.vm.network  "private_network", ip: "192.168.56.11"
        centos.vm.provider "virtualbox" do |vb|
            vb.memory = 1024
            vb.cpus = 1
        end
        centos.vm.provision "shell" , inline: <<-SHELL
          sudo dnf install -y python3 python3-pip
          pip3 install --upgrade pip
          pip3 install requests 
           mkdir -p /home/vagrant/.ssh
          echo "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGzAHaxmp1KTOKMMC5u14cpbTX0WUM1Xnve0GBCL99cm assag@DESKTOP-APSQTK1" >> /home/vagrant/.ssh/authorized_keys
          chmod 600 /home/vagrant/.ssh/authorized_keys
          chown -R vagrant:vagrant /home/vagrant/.ssh
        SHELL
    end
end
